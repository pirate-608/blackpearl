{
  "name": "blackpearl-agent",
  "version": "0.1.2",
  "description": "A TypeScript + Ink TUI multi-provider AI Agent framework for educational use.",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.12.1",
  "bin": {
    "blackpearl": "./dist/cli.js"
  },
  "scripts": {
    "dev": "tsx src/index.tsx",
    "web": "tsx src/app/web/server.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "start:web": "node dist/app/web/server.js",
    "package:bundle": "node scripts/build-sea.mjs bundle",
    "package:sea": "node scripts/build-sea.mjs sea",
    "package:smoke": "node scripts/build-sea.mjs smoke",
    "test": "vitest run",
    "lint": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.98.0",
    "@inkjs/ui": "^2.0.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "dotenv": "^16.4.7",
    "expr-eval": "^2.0.2",
    "ink": "^5.1.0",
    "mammoth": "^1.12.0",
    "marked": "^18.0.4",
    "openai": "^6.39.0",
    "pdf-parse": "^2.4.5",
    "picocolors": "^1.1.1",
    "react": "^18.3.1",
    "zod": "^3.24.1",
    "zod-to-json-schema": "^3.24.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.7",
    "@types/react": "^18.3.18",
    "esbuild": "0.28.0",
    "rcedit": "^5.0.2",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "vitest": "^2.1.8"
  }
}
